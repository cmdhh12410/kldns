# KLDNS Cloudflare Workers 环境变量配置
# 复制本文件为 .env（或 .dev.vars）并填入真实值。
# Wrangler 在本地开发时读取 .dev.vars，生产环境变量通过 `wrangler secret put` 设置。

# ============ 应用基础配置 ============
# 应用名称，用于日志、Cookie 前缀等
APP_NAME=kldns

# 运行模式：dev | production
# production 模式下会强制校验 SECRET_KEY 不能为默认值
APP_MODE=production

# ============ 安全配置 ============
# JWT / Token 签名密钥，必须修改为随机字符串
# 生成方式示例：openssl rand -hex 32
SECRET_KEY=change-me-before-production-kldns-secret

# ============ Cloudflare D1 数据库 ============
# 在 wrangler.toml 中通过 [[d1_databases]] 绑定，
# 这里列出便于脚本使用的逻辑 ID（实际 ID 写入 wrangler.toml）
D1_DATABASE_NAME=kldns-db
D1_DATABASE_ID=your-d1-database-id

# ============ Cloudflare KV 命名空间 ============
# 用于存储前端静态资源、应用设置等
# 在 wrangler.toml 中通过 [[kv_namespaces]] 绑定
KV_NAMESPACE_NAME=kldns-kv
KV_NAMESPACE_ID=your-kv-namespace-id

# ============ Turnstile 人机验证（可选） ============
# 从 https://dash.cloudflare.com/ 申请
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============ DNS 提供商密钥（按需配置） ============
# 管理后台在添加域名时配置，通常不需要写进环境变量；
# 如需在部署脚本中预置，可在此补充：
# CLOUDFLARE_API_TOKEN=
# DNSPOD_SECRET_ID=
# DNSPOD_SECRET_KEY=
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
